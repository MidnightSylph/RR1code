}

// --- Додаткові функції ---
void exportToCSV() {
    if (!isLicensed) { cout << "Функція недоступна.\n"; return; }
    string fname;
    cout << "Введіть ім'я файлу (наприклад, base.csv): ";
    cin >> fname;
    ofstream out(fname);
    if (!out) { cout << "Помилка!\n"; return; }
    
    Node* temp = head;
    while (temp) {
        out << temp->data.fullName << ";"
            << temp->data.position << ";"
            << temp->data.hireDate.day << "." << temp->data.hireDate.month << "." << temp->data.hireDate.year << ";"
            << temp->data.salary << "\n";
        temp = temp->next;
    }
    out.close();
    cout << "Експортовано успішно!\n";
}

void saveAsDB() {
    if (!isLicensed) { cout << "Функція недоступна.\n"; return; }
    string fname;
    cout << "Введіть нове ім'я файлу БД: ";
    cin >> fname;
    saveDB(fname);
    cout << "Збережено як " << fname << "\n";
}

void editConfigMenu() {
    if (!isLicensed) { cout << "Функція недоступна.\n"; return; }
    cout << "1. Змінити ім'я файлу БД (Зараз: " << currentDbFilename << ")\n";
    cout << "2. Змінити ліцензійний ключ (Зараз: " << currentKey << ")\n";
    int choice;
    cin >> choice;
    if (choice == 1) {
        cout << "Нове ім'я: ";
        cin >> currentDbFilename;
    } else if (choice == 2) {
        cout << "Новий ключ: ";
        cin >> currentKey;
        isLicensed = validateLicense(currentKey);
    }
    saveConfig();
    loadDB(currentDbFilename);
}

