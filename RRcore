using namespace std;

// --- Структури даних ---
struct Date {
    int day, month, year;
};

struct Employee {
    char fullName[100];
    char position[100];
    Date hireDate;
    float salary;
};

struct Node {
    Employee data;
    Node* next;
};

// --- Глобальні змінні ---
Node* head = nullptr;
string currentDbFilename = "new_base.dat";
string currentKey = "";
bool isLicensed = false;
string configFilename = "";

// --- Допоміжні функції (Очищення пам'яті) ---
void clearList() {
    while (head != nullptr) {
        Node* temp = head;
        head = head->next;
        delete temp;
    }
}

// --- Логіка ліцензійного ключа ---
bool validateLicense(const string& key) {
    if (key.empty()) return false;
    int sum = 0;
    for (char c : key) sum += c;
    return (sum % 10 == 1);
}

// --- Робота з конфігураційним файлом ---
string getExeName(const char* argv0) {
    string path(argv0);
    size_t pos = path.find_last_of("/\\");
    string filename = (pos == string::npos) ? path : path.substr(pos + 1);
    size_t dotPos = filename.find_last_of(".");
    if (dotPos != string::npos) {
        filename = filename.substr(0, dotPos);
    }
    return filename + ".cfg";
}

void createDefaultConfig(const string& cfgName) {
    ofstream out(cfgName);
    if (out) {
        out << "; Файл бази даних\n";
        out << "DB = new_base.dat\n";
        out << "; Ліцензійний ключ\n";
        out << "KEY = \n";
        out.close();
        cout << "[УВАГА] Створено новий конфігураційний файл: " << cfgName << "\n";
    }
}

void loadConfig(const string& cfgName) {
    ifstream in(cfgName);
    if (!in) {
        createDefaultConfig(cfgName);
        in.open(cfgName);
    }
    
    string line;
    while (getline(in, line)) {
        if (line.empty() || line[0] == ';') continue;
        
        size_t eqPos = line.find('=');
        if (eqPos != string::npos) {
            string key = line.substr(0, eqPos);
            string val = line.substr(eqPos + 1);
            
            // Trim spaces
            key.erase(0, key.find_first_not_of(" \t"));
            key.erase(key.find_last_not_of(" \t") + 1);
            val.erase(0, val.find_first_not_of(" \t"));
            val.erase(val.find_last_not_of(" \t") + 1);
            
            if (key == "DB") currentDbFilename = val;
            else if (key == "KEY") currentKey = val;
        }
    }
    in.close();
    
    isLicensed = validateLicense(currentKey);
    if (!isLicensed) {
        cout << "[ПОПЕРЕДЖЕННЯ] Ліцензійний ключ відсутній або некоректний!\n";
        cout << "Спеціальні та додаткові функції заблоковано.\n\n";
    }
}

void saveConfig() {
    ofstream out(configFilename);
    if (out) {
        out << "; Файл бази даних\n";
        out << "DB = " << currentDbFilename << "\n";
        out << "; Ліцензійний ключ\n";
        out << "KEY = " << currentKey << "\n";
        out.close();
        cout << "Конфігурацію збережено.\n";
    }
}

// --- Робота з бінарним файлом бази даних ---
void loadDB(const string& filename) {
    clearList();
    ifstream in(filename, ios::binary);
    if (!in) {
        cout << "[УВАГА] Файл БД " << filename << " не знайдено. Створюємо новий.\n";
        ofstream out(filename, ios::binary);
        out.close();
        return;
    }
    
    Employee emp;
    Node* tail = nullptr;
    while (in.read((char*)&emp, sizeof(Employee))) {
        Node* newNode = new Node{emp, nullptr};
        if (!head) {
            head = newNode;
            tail = newNode;
        } else {
            tail->next = newNode;
            tail = newNode;
        }
    }
    in.close();
}

void saveDB(const string& filename) {
    ofstream out(filename, ios::binary);
    if (!out) {
        cout << "Помилка збереження файлу!\n";
        return;
    }
    Node* temp = head;
    while (temp) {
        out.write((char*)&temp->data, sizeof(Employee));
        temp = temp->next;
    }
    out.close();
}

// --- Основні функції ---
void addRecord() {
    Employee emp;
    cout << "Введіть ПІБ: ";
    cin.ignore();
    cin.getline(emp.fullName, 100);
    cout << "Введіть посаду: ";
    cin.getline(emp.position, 100);
    cout << "Введіть дату прийняття (ДД ММ РРРР через пробіл): ";
    cin >> emp.hireDate.day >> emp.hireDate.month >> emp.hireDate.year;
    cout << "Введіть заробітну плату: ";
    cin >> emp.salary;
    
    Node* newNode = new Node{emp, nullptr};
    if (!head) head = newNode;
    else {
        Node* temp = head;
        while (temp->next) temp = temp->next;
        temp->next = newNode;
    }
    saveDB(currentDbFilename);
    cout << "Запис додано!\n";
}

void viewRecords() {
    if (!head) {
        cout << "База даних порожня.\n";
        return;
    }
    Node* temp = head;
    int index = 1;
    cout << string(80, '-') << "\n";
    cout << left << setw(5) << "№" << setw(30) << "ПІБ" << setw(20) << "Посада" 
         << setw(15) << "Дата" << "З/П\n";
    cout << string(80, '-') << "\n";
    while (temp) {
        cout << left << setw(5) << index++ 
             << setw(30) << temp->data.fullName 
             << setw(20) << temp->data.position 
             << right << setfill('0') << setw(2) << temp->data.hireDate.day << "."
             << setw(2) << temp->data.hireDate.month << "."
             << setw(4) << temp->data.hireDate.year << setfill(' ') << left << "   "
             << temp->data.salary << "\n";
        temp = temp->next;
    }
