}

void deleteRecord() {
    viewRecords();
    if (!head) return;
    int index;
    cout << "Введіть номер запису для видалення: ";
    cin >> index;
    
    if (index == 1) {
        Node* toDelete = head;
        head = head->next;
        delete toDelete;
        saveDB(currentDbFilename);
        cout << "Запис видалено.\n";
        return;
    }
    
    Node* temp = head;
    for (int i = 1; i < index - 1 && temp != nullptr; i++) {
        temp = temp->next;
    }
    
    if (!temp || !temp->next) {
        cout << "Запис з таким номером не знайдено.\n";
        return;
    }
    
    Node* toDelete = temp->next;
    temp->next = toDelete->next;
    delete toDelete;
    saveDB(currentDbFilename);
    cout << "Запис видалено.\n";
}

void editRecord() {
    viewRecords();
    if (!head) return;
    int index;
    cout << "Введіть номер запису для редагування: ";
    cin >> index;
    
    Node* temp = head;
    for (int i = 1; i < index && temp != nullptr; i++) {
        temp = temp->next;
    }
    
    if (!temp) {
        cout << "Запис з таким номером не знайдено.\n";
        return;
    }
    
    cout << "Нове ПІБ (старе: " << temp->data.fullName << "): ";
    cin.ignore();
    cin.getline(temp->data.fullName, 100);
    cout << "Нова посада: ";
    cin.getline(temp->data.position, 100);
    cout << "Нова дата прийняття (ДД ММ РРРР): ";
    cin >> temp->data.hireDate.day >> temp->data.hireDate.month >> temp->data.hireDate.year;
    cout << "Нова з/п: ";
    cin >> temp->data.salary;
    
    saveDB(currentDbFilename);
    cout << "Запис змінено.\n";
}

// --- Спеціальні функції (Варіант 13) ---
bool isAfter(Date d1, Date ref) {
    if (d1.year > ref.year) return true;
    if (d1.year == ref.year && d1.month > ref.month) return true;
    if (d1.year == ref.year && d1.month == ref.month && d1.day > ref.day) return true;
    return false;
}

void specialFunc1() {
    if (!isLicensed) { cout << "Функція недоступна (немає ліцензії).\n"; return; }
    
    char searchPos[100];
    Date refDate;
    cout << "Введіть посаду: ";
    cin.ignore();
    cin.getline(searchPos, 100);
    cout << "Введіть дату (ДД ММ РРРР): ";
    cin >> refDate.day >> refDate.month >> refDate.year;
    
    bool found = false;
    Node* temp = head;
    while (temp) {
        if (strcmp(temp->data.position, searchPos) == 0 && isAfter(temp->data.hireDate, refDate)) {
            cout << temp->data.fullName << " | " << temp->data.salary << "\n";
            found = true;
        }
        temp = temp->next;
    }
    if (!found) cout << "Співробітників не знайдено.\n";
}

void specialFunc2() {
    if (!isLicensed) { cout << "Функція недоступна (немає ліцензії).\n"; return; }
    
    float minSalary;
    cout << "Введіть мінімальну заробітну плату: ";
    cin >> minSalary;
    
    bool found = false;
